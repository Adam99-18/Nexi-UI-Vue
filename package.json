{
  "name": "nexi-ui",
  "version": "1.0.2",
  "description": "Nexi-UI Vue 4.x — 企业级后台管理系统组件库，基于 Ant Design Vue 深度封装",
  "type": "module",
  "author": "Adam",
  "main": "./dist/nexi-ui.cjs",
  "module": "./dist/nexi-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/nexi-ui.js",
      "require": "./dist/nexi-ui.cjs"
    },
    "./dist/*": "./dist/*",
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "*.css",
    "*.scss",
    "*.vue"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && node scripts/build-types.mjs",
    "docs:dev": "vitepress dev docs --port 5180",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vue",
    "vue3",
    "ant-design-vue",
    "admin",
    "component-library",
    "ui-components",
    "dashboard",
    "enterprise",
    "Nexi-ui",
    "nexi-vue"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/Nexi-ui"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@ant-design/icons-vue": "^7.0.0",
    "ant-design-vue": "^4.0.0",
    "vue": "^3.3.0"
  },
  "dependencies": {
    "dayjs": "^1.11.13",
    "lodash-es": "^4.17.21",
    "sortablejs": "^1.15.6",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/sortablejs": "^1.15.8",
    "@ant-design/icons-vue": "^7.0.1",
    "ant-design-vue": "^4.0.0",
    "sass": "^1.83.4",
    "typescript": "^5.7.3",
    "vitepress": "^1.6.3",
    "vue": "^3.3.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "vite": "^5.4.21"
  }
}
