{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./*"],
      "~/*": ["./*"],
      "@@/*": ["./*"]
    },
    "baseUrl": "."
  },
  "include": [
    "antd/**/*.vue",
    "antd/**/*.ts",
    "antd/**/*.tsx",
    "docs/**/*.ts",
    "docs/**/*.vue",
    "docs/**/*.md"
  ],
  "exclude": ["node_modules"]
}
